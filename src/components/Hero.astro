---
import Badge from "./Badge.astro";
---

<section
  class="flex flex-col items-center text-center px-6 py-24 bg-gradient-to-r from-primary to-secondary text-white overflow-hidden fade-up-delay-1"
>
  <div class="flex items-center gap-3 fade-up-delay-1">
    <h1 class="text-4xl md:text-5xl font-bold">Hola, soy Franco</h1>
    <Badge />
  </div>

  <p class="text-lg md:text-xl max-w-xl mt-6 mb-6 opacity-90 fade-up-delay-2">
    Desarrollador web y freelance. Creo soluciones digitales atractivas y
    funcionales que ayudan a negocios a crecer.
  </p>

  <a
    href="#portfolio"
    class="bg-white text-secondary font-semibold px-6 py-3 rounded-md shadow-md transition hover:text-primary fade-up-delay-3"
  >
    Ver mis proyectos
  </a>
  <div class="flex items-center gap-6 mt-6 fade-up-delay-4">
    <a
      href="https://github.com/FrancoScript"
      target="_blank"
      rel="noopener"
      class="flex items-center gap-2 text-white/90 hover:text-white transition"
    >
      <img src="/github.png" alt="Github" class="w-6 h-6" />
      <span>GitHub</span>
    </a>

    <a
      href="https://www.linkedin.com/in/francodiazp"
      target="_blank"
      rel="noopener"
      class="flex items-center gap-2 text-white/90 hover:text-white transition"
    >
      <img src="/linkedin.png" alt="LinkedIn" class="w-6 h-6" />
      <span>LinkedIn</span>
    </a>
  </div>
</section>
