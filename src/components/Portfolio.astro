---
const { title, desc, img } = Astro.props;
---

<div
  class="bg-white rounded-xl overflow-hidden shadow-md border border-primary/10 transition-transform duration-300 hover:shadow-xl hover:scale-[1.03]"
>
  <img class="h-48 w-full object-cover" src={img} alt={title} />
  <div class="p-4">
    <h3 class="text-xl font-semibold text-secondary mb-2">{title}</h3>
    <p class="text-sm text-gray-600">
      {desc}
    </p>
  </div>
</div>
